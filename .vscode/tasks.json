{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake: configure (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "${workspaceFolder}",
        "-B",
        "${workspaceFolder}/build",
        "-DCMAKE_BUILD_TYPE=Debug"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "build engine",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "${workspaceFolder}/build", "-j"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "configure and build engine (Debug)",
      "dependsOrder": "sequence",
      "dependsOn": ["cmake: configure (Debug)", "build engine"],
      "problemMatcher": [],
      "group": "build"
    }
  ]
}
